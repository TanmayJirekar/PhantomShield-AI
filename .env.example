# PhantomShield AI - Environment Configuration
# Copy this file to backend/.env and fill in your keys

# Required for AI Cyber Assistant chat
GROQ_API_KEY=Your_Groq_apikey

# Optional - enables VirusTotal URL reputation checks
# Get a free key at https://www.virustotal.com/
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# Optional Flask secret (defaults to dev key if unset)
SECRET_KEY=change-this-in-production
